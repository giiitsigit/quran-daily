{
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/wallpaper", "destination": "/api/wallpaper.js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
